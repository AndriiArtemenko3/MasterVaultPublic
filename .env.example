# Copy to .env and fill in what you have. Everything is optional:
# - No keys at all -> local embeddings + mock LLM (search works fully; `ask` gives extractive answers)
# - DATABASE_URL unset -> SQLite backend (no Docker needed)

# Postgres (docker compose up -d gives you this one)
DATABASE_URL=postgresql://mastervault:mastervault@localhost:5433/mastervault

# LLM providers (either one enables real agentic ask/ingest)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional cross-encoder reranking
COHERE_API_KEY=
